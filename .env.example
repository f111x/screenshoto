# ============================================
# AI Provider Configuration
# ============================================
# Supported providers:
#   openai    — OpenAI GPT-4o (default)
#   dashscope — 阿里云通义千问 Qwen-VL-Max
#   zhipu     — 智谱 GLM-4V-Plus
#   deepseek  — DeepSeek Chat
#   moonshot  — 月之暗面 Kimi Vision
#   stepfun   — 阶跃星辰 Step-2V
#   custom    — 自定义 OpenAI 兼容 API
AI_PROVIDER=dashscope

# AI API Key (根据上面选择的 provider 填写对应平台的 key)
AI_API_KEY=sk-your-api-key-here

# 如果使用 custom provider，需要额外指定 base URL 和 model
# AI_BASE_URL=https://your-custom-api.com/v1
# AI_MODEL=your-model-name

# ============================================
# Legacy / Fallback (兼容旧配置)
# 如果 AI_API_KEY 为空，会尝试读取 OPENAI_API_KEY
# ============================================
# OPENAI_API_KEY=sk-your-openai-key

# ============================================
# Public API Key (用于 REST API 访问)
# 设置后可对外暴露 API 接口，用户需提供此 key
# ============================================
# API_KEY=your-public-api-key
